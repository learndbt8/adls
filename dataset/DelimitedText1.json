			},
			{
				"name": "email",
				"type": "String"
			},
			{
				"name": "department",
				"type": "String"
			},
			{
				"name": "salary",
				"type": "String"
			},
			{
				"name": "joining_date",
				"type": "String"
			},
			{
				"name": "city",
				"type": "String"
			}
		]
